# DNS Security Proxy
# Все протоколы → ваш сервис через DNS-over-TCP

. {
    # ВСЕ запросы форвардим в ваше приложение
    forward . dns-proxy:5353 {
        # Оптимизации производительности
        max_concurrent 10000        # До 10к одновременных запросов
        expire 30s                  # Таймаут idle соединений
        health_check 10s            # Проверка здоровья
        policy sequential           # Простая политика
        prefer_udp                  # Предпочитать UDP для апстрима
    }
    
    # Кеширование на стороне CoreDNS (опционально)
    cache {
        success 10000 3600 300      # Успешные ответы
        denial 10000 3600 300       # Ошибочные ответы
        prefetch 1000 10m 80%       # Предзагрузка популярных
    }
    
    # Логирование всех запросов
    log . {
        class all
        format combined
    }
    
    # Обработка ошибок
    errors {
        consolidate 5s 100          # Консолидация ошибок
    }
    
    # Метрики Prometheus
    prometheus 0.0.0.0:9091
    
    # Health check
    health 0.0.0.0:8080
    
    # Защита от DDoS
    bind 0.0.0.0
    
    # Увеличиваем лимиты
    bufsize 1232                    # EDNS0 buffer size
}
