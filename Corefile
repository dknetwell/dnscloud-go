.:53 {
    # Наш security плагин
    security {
        # Конфиг файл
        config /app/config/config.yaml
    }
    
    # Forward для разрешенных доменов
    forward . 8.8.8.8 1.1.1.1 {
        max_fails 3
        health_check 5s
        policy sequential
    }
    
    # Кеширование DNS ответов
    cache {
        success 10000 3600 300
        denial 10000 3600 300
    }
    
    # Логирование
    log . {
        class all
    }
    
    errors
    
    # Prometheus метрики
    prometheus :9091
    
    # Health checks
    health :8080
}
